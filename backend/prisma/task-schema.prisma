model Tasks {
  id          Int       @id @default(autoincrement())
  user_id     Int
  title       String    @db.VarChar(255)
  description String?
  status      String?   @default("OPEN") @db.VarChar(20)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  user        Users     @relation(fields: [user_id], references: [id])
}
